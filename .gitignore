claude\ historial/

# Datos y graficas experimentales: no versionar (solo .gitkeep en data/ y plots/)
data/**/*.csv
data/**/*.yaml
plots/**/*.png
plots/**/*.eps
plots/**/*.pdf

# Salidas generadas por el pipeline de identificacion (src/Identification):
# el modelo final revisado se copia a mano a motorXM430W350T_params.yaml
config/motorXM430W350T_params_identified.yaml
config/motorXM430W350T_params_posmode.yaml

# Bytecode de Python (launch files)
__pycache__/

# Salidas de ejecucion de MATLAB (Lab 5): logs de fmincon y soluciones .mat
src/Trajectory Optimization TV-LQR/MATLAB/logs/
src/Trajectory Optimization TV-LQR/MATLAB/zmin/

# Binarios MEX y carpeta de trabajo de MATLAB Coder (build_omdyn_mex.m)
*.mexa64
*.mexw64
*.mexmaci64
codegen/

# Excepcion: el Prelab FL es una carpeta portable autocontenida — su MEX
# Linux SI se versiona para que funcione al clonar (en Windows: OMDyn.m
# o compilar OMDyn.mexw64 con build_omdyn_mex.m)
!src/Feedback Linearization/MATLAB/Prelab/instructor/OMDyn.mexa64

# Excepcion: los MEX Linux del Lab 5 (TV-LQR) SI se versionan — los scripts
# de instructor y las plantillas de estudiante asumen OMDyn.mexa64 y
# open_manx_fkin.mexa64 precompilados en su misma carpeta (solo Linux;
# en Windows recompilar con MATLAB Coder). codegen/ sigue ignorado.
!src/Trajectory Optimization TV-LQR/MATLAB/instructor/OMDyn.mexa64
!src/Trajectory Optimization TV-LQR/MATLAB/instructor/open_manx_fkin.mexa64
!src/Trajectory Optimization TV-LQR/MATLAB/student/OMDyn.mexa64
!src/Trajectory Optimization TV-LQR/MATLAB/student/open_manx_fkin.mexa64

# Backup transitorio que crea gen_OMDyn.m en cada regeneracion
OMDyn_prev.m
