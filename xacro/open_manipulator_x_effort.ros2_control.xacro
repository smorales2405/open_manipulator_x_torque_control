<?xml version="1.0"?>
<!--
  ros2_control exclusivo para simulacion Gazebo Fortress con command_interface effort.
  ADVERTENCIA: No compatible con hardware real Dynamixel.

  Usa gz_ros2_control/GazeboSimSystem (Gazebo Fortress / Ignition Gazebo 6).
  GazeboSimSystem soporta effort puro sin necesidad del workaround de "position"
  que requeria gazebo_ros2_control/GazeboSystem 0.4.x.

  Parametros del macro:
    use_fixed_init  True|False   — si True, aplica initial_value en cada joint
    q1_init .. q4_init  [rad]   — posiciones iniciales (solo si use_fixed_init=True)

  Notas de implementacion:
    - El default debe ser el booleano Python False (no la cadena 'false'),
      porque xacro convierte 'false' a False pero 'false'!='true' falla en
      la comparacion == al recibir el bool True desde xacro:arg.
    - xacro:if debe envolver bloques completos de state_interface, no
      solo el param interno (limitacion del parser xacro).
    - Condicion: ${use_fixed_init} — truthy check directo sobre el bool Python.
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:macro name="open_manipulator_x_effort_system"
               params="name prefix
                       use_fixed_init:=False
                       q1_init:=0.0  q2_init:=0.0
                       q3_init:=0.0  q4_init:=0.0">

    <ros2_control name="${name}" type="system">

      <hardware>
        <plugin>gz_ros2_control/GazeboSimSystem</plugin>
      </hardware>

      <!-- ── joint1 ────────────────────────────────────────────────────── -->
      <joint name="${prefix}joint1">
        <command_interface name="effort">
          <param name="min">-1.5</param>
          <param name="max"> 1.5</param>
        </command_interface>
        <xacro:if value="${use_fixed_init}">
          <state_interface name="position">
            <param name="initial_value">${q1_init}</param>
          </state_interface>
          <state_interface name="velocity">
            <param name="initial_value">0.0</param>
          </state_interface>
        </xacro:if>
        <xacro:unless value="${use_fixed_init}">
          <state_interface name="position"/>
          <state_interface name="velocity"/>
        </xacro:unless>
        <state_interface name="effort"/>
      </joint>

      <!-- ── joint2 ────────────────────────────────────────────────────── -->
      <joint name="${prefix}joint2">
        <command_interface name="effort">
          <param name="min">-1.5</param>
          <param name="max"> 1.5</param>
        </command_interface>
        <xacro:if value="${use_fixed_init}">
          <state_interface name="position">
            <param name="initial_value">${q2_init}</param>
          </state_interface>
          <state_interface name="velocity">
            <param name="initial_value">0.0</param>
          </state_interface>
        </xacro:if>
        <xacro:unless value="${use_fixed_init}">
          <state_interface name="position"/>
          <state_interface name="velocity"/>
        </xacro:unless>
        <state_interface name="effort"/>
      </joint>

      <!-- ── joint3 ────────────────────────────────────────────────────── -->
      <joint name="${prefix}joint3">
        <command_interface name="effort">
          <param name="min">-1.5</param>
          <param name="max"> 1.5</param>
        </command_interface>
        <xacro:if value="${use_fixed_init}">
          <state_interface name="position">
            <param name="initial_value">${q3_init}</param>
          </state_interface>
          <state_interface name="velocity">
            <param name="initial_value">0.0</param>
          </state_interface>
        </xacro:if>
        <xacro:unless value="${use_fixed_init}">
          <state_interface name="position"/>
          <state_interface name="velocity"/>
        </xacro:unless>
        <state_interface name="effort"/>
      </joint>

      <!-- ── joint4 ────────────────────────────────────────────────────── -->
      <joint name="${prefix}joint4">
        <command_interface name="effort">
          <param name="min">-1.5</param>
          <param name="max"> 1.5</param>
        </command_interface>
        <xacro:if value="${use_fixed_init}">
          <state_interface name="position">
            <param name="initial_value">${q4_init}</param>
          </state_interface>
          <state_interface name="velocity">
            <param name="initial_value">0.0</param>
          </state_interface>
        </xacro:if>
        <xacro:unless value="${use_fixed_init}">
          <state_interface name="position"/>
          <state_interface name="velocity"/>
        </xacro:unless>
        <state_interface name="effort"/>
      </joint>

      <!-- ── Gripper: solo control de posicion ─────────────────────────── -->
      <joint name="${prefix}gripper_left_joint">
        <command_interface name="position"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
        <state_interface name="effort"/>
      </joint>

      <joint name="${prefix}gripper_right_joint">
        <param name="mimic">${prefix}gripper_left_joint</param>
        <param name="multiplier">1</param>
        <command_interface name="position"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
        <state_interface name="effort"/>
      </joint>

    </ros2_control>

  </xacro:macro>

</robot>
